{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "WorkflowOS: Run",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "app.main:app",
                "--reload",
                "--host", "127.0.0.1",
                "--port", "8000"
            ],
            "python": "${workspaceFolder}/venv/Scripts/python.exe",
            "jinja": true,
            "envFile": "${workspaceFolder}/.env"
        },
        {
            "name": "WorkflowOS: Debug",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "app.main:app",
                "--host", "127.0.0.1",
                "--port", "8000"
            ],
            "python": "${workspaceFolder}/venv/Scripts/python.exe",
            "jinja": true,
            "envFile": "${workspaceFolder}/.env"
        }
    ]
}